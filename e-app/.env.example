# =====================================================
# E-Learning Platform – Frontend environment variables
# Copy this file to .env and adjust as needed.
# Vite only exposes vars prefixed with VITE_ to the app.
# =====================================================

# Base URL of the backend API (no trailing slash)
VITE_API_BASE_URL=http://localhost:5000/api

# App display name (optional)
VITE_APP_NAME=E-Learning Platform

# RAG chatbot backend (no trailing slash)
VITE_RAG_API_URL=https://your-rag-backend.onrender.com
